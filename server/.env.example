# ═══════════════════════════════════════════════
# CivicEye Server — Environment Variables
# Copy this to .env and fill in values from Supabase
# ═══════════════════════════════════════════════

# ── Supabase PostgreSQL Connection ──
# Find this in: Supabase Dashboard → Project → Settings → Database → Connection string (URI mode)
# Use the "Transaction Pooler" (port 6543) for serverless/Railway deployments
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── JWT Secret ──
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-strong-secret-here

# ── Server Port ──
PORT=4000

# ── Node Environment ──
NODE_ENV=production
